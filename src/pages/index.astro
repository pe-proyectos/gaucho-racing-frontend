---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

import Navbar from '../components/Navbar.tsx';
import Hero from '../components/Hero.tsx';
import History from '../components/History.tsx';
import Riders from '../components/Riders.tsx';
import Motorbike from '../components/Motorbike.tsx';
import Gallery from '../components/Gallery.tsx';
import Sponsors from '../components/Sponsors.tsx';
import Footer from '../components/Footer.tsx';
---

<Layout>
  <Navbar client:load />
  
  <main>
    <Hero />
    <History />
    <Riders />
    <Motorbike />
    <Gallery />
    <Sponsors />
  </main>

  <Footer />

  <script>
    // Intersection Observer for scroll animations
    const setupObserver = () => {
      const animEls = document.querySelectorAll('.fade-up, .clip-reveal, .scale-in');
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add('visible');
            }
          });
        },
        { threshold: 0.05, rootMargin: '0px 0px -50px 0px' }
      );
      animEls.forEach((el) => observer.observe(el));
    };

    // Run setup
    setupObserver();
    
    // For Potential client-side routing/re-renders with Astro segments
    document.addEventListener('astro:page-load', setupObserver);
    document.addEventListener('astro:after-swap', setupObserver);
  </script>

  <style is:global>
    /* Add any global styles that are shared across React components if needed */
    .nav-link {
      font-size: 0.7rem;
      font-weight: 500;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: rgba(10, 10, 10, 0.6);
      text-decoration: none;
      transition: color 0.25s ease;
    }
    .nav-link:hover {
      color: #0a0a0a;
    }
    .nav-link.cta-nav {
      color: #6cace4;
      border: 1px solid rgba(108, 172, 228, 0.35);
      padding: 0.45rem 1rem;
      border-radius: 2px;
    }
    .nav-link.cta-nav:hover {
      background: rgba(108, 172, 228, 0.1);
      color: #6cace4;
    }

    .btn-primary {
      display: inline-block;
      padding: 0.9rem 2rem;
      background: #6cace4;
      color: #0a0a0a;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      text-decoration: none;
      border: 1px solid #6cace4;
      transition: all 0.3s ease;
      border-radius: 2px;
    }
    .btn-primary:hover {
      background: #ffb81c;
      border-color: #ffb81c;
      color: #0a0a0a;
    }

    .btn-ghost {
      display: inline-block;
      padding: 0.9rem 2rem;
      background: transparent;
      color: rgba(10, 10, 10, 0.6);
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      text-decoration: none;
      border: 1px solid rgba(10, 10, 10, 0.2);
      transition: all 0.3s ease;
      border-radius: 2px;
    }
    .btn-ghost:hover {
      border-color: rgba(108, 172, 228, 0.5);
      color: #6cace4;
    }

    .gallery-item:hover .placeholder-box {
      transform: scale(1.02);
    }

    .hover-scale:hover {
      transform: scale(1.08);
    }

    .footer-link {
      font-size: 0.85rem;
      color: rgba(255, 255, 255, 0.5);
      text-decoration: none;
      font-weight: 300;
      transition: color 0.25s ease;
    }
    .footer-link:hover {
      color: #6cace4;
    }

    .social-link {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 36px;
      height: 36px;
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.65rem;
      font-weight: 600;
      letter-spacing: 0.05em;
      text-decoration: none;
      border-radius: 2px;
      transition: all 0.3s ease;
    }
    .social-link:hover {
      border-color: #6cace4;
      color: #6cace4;
      background: rgba(108, 172, 228, 0.1);
    }
  </style>
</Layout>
