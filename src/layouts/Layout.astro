---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Gaucho Racing — Isle of Man TT 2025',
  description = 'Equipo argentino de carreras de motos. Velocidad. Precisión. Pasión. Isle of Man TT 2025.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/isotipo_guacho_racing.png" />
</head>
<body>
  <slot />
</body>
</html>
